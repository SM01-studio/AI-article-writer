# AI Article Writer - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== API Keys ====================

# GLM (智谱AI) API Key - 用于内容生成
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# Gemini API Key - 用于图片生成
# 获取地址: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== 服务器配置 ====================

# Flask 环境 (development/production)
FLASK_ENV=production

# Flask 密钥 (用于 session 加密，生成一个随机字符串)
SECRET_KEY=your_random_secret_key_here

# ==================== CORS 配置 ====================

# 允许的跨域来源，多个用逗号分隔
# 开发环境: *
# 生产环境: https://your-app.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=*

# ==================== 可选配置 ====================

# 服务器端口 (默认 5000)
PORT=5000

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
